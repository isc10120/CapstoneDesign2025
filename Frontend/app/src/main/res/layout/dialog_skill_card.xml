<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✨ 스킬 획득!"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/main_navy"
        android:layout_marginBottom="16dp" />

    <ImageView
        android:id="@+id/iv_skill_image"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:scaleType="centerCrop"
        android:background="#EEE"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tv_skill_grade"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="은급"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:background="@drawable/bg_count_badge"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_skill_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="스킬명"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/overlay_text_primary"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tv_skill_damage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="데미지: 0"
        android:textSize="16sp"
        android:textColor="#F44336"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_skill_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="스킬 설명"
        android:textSize="14sp"
        android:textColor="@color/overlay_text_secondary"
        android:gravity="center"
        android:layout_marginBottom="4dp" />

</LinearLayout>
