<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <!-- 스킬 발동 타이틀 -->
    <TextView
        android:id="@+id/tv_skill_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚔ 스킬 발동!"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/main_navy"
        android:layout_marginBottom="12dp" />

    <!-- 카드 프레임 영역 -->
    <FrameLayout
        android:layout_width="200dp"
        android:layout_height="280dp">

        <ImageView
            android:id="@+id/iv_skill_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="72dp"
            android:scaleType="centerCrop"
            android:background="#CCCCCC" />

        <ImageView
            android:id="@+id/iv_card_frame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/cardframe_silver"
            android:scaleType="fitXY" />

        <!-- 스킬 이름 (카드 프레임 위에 오버레이) -->
        <TextView
            android:id="@+id/tv_skill_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="82dp"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:text="스킬명"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- 데미지 (카드 프레임 위에 오버레이) -->
        <TextView
            android:id="@+id/tv_skill_damage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginBottom="38dp"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:text="+0 데미지!"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#CC3333"
            android:maxLines="1" />

    </FrameLayout>

    <!-- 스킬 설명 -->
    <TextView
        android:id="@+id/tv_skill_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="8dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        android:text="스킬 설명"
        android:textSize="12sp"
        android:textColor="#555555"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="10dp" />

    <!-- 부가효과 -->
    <TextView
        android:id="@+id/tv_skill_effect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="부가효과: X"
        android:textSize="13sp"
        android:textColor="#666"
        android:layout_marginBottom="4dp" />

    <!-- 누적 총 데미지 -->
    <TextView
        android:id="@+id/tv_total_damage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="누적 데미지: 0"
        android:textSize="13sp"
        android:textColor="#666"
        android:layout_marginBottom="10dp" />

    <!-- 수집 완료 뱃지 -->
    <TextView
        android:id="@+id/tv_collected_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📦 카드 수집 완료"
        android:textSize="13sp"
        android:textColor="#388E3C"
        android:textStyle="bold" />

</LinearLayout>
