<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="170dp"
    android:layout_margin="5dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardBackgroundColor="#2A2A4E"
        app:cardCornerRadius="10dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- 등급 + 효과 타입 (상단 행) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/tv_grade"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_count_badge"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="동급"
                    android:textColor="@color/white"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tv_effect_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚔ 공격"
                    android:textColor="#F4C400"
                    android:textSize="9sp" />
            </LinearLayout>

            <!-- 스킬 이름 (가운데, 메인) -->
            <TextView
                android:id="@+id/tv_skill_name"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="3"
                android:text="스킬명"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- 구분선 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#44445E"
                android:layout_marginVertical="6dp" />

            <!-- 데미지 -->
            <TextView
                android:id="@+id/tv_damage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DMG 50"
                android:textColor="#FF7777"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="3dp" />

            <!-- 단어 -->
            <TextView
                android:id="@+id/tv_word"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:text="word"
                android:textColor="#8888AA"
                android:textSize="9sp"
                android:textStyle="italic" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 선택 오버레이 -->
    <FrameLayout
        android:id="@+id/selected_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#884CAF50"
        android:visibility="gone">

        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="top|end"
            android:layout_margin="4dp"
            android:background="#CC4CAF50"
            android:gravity="center"
            android:text="✓"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- 잠금 오버레이 -->
    <FrameLayout
        android:id="@+id/locked_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA111122"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="🔒&#10;재사용 불가"
            android:textColor="@color/white"
            android:textSize="11sp" />
    </FrameLayout>

</FrameLayout>
