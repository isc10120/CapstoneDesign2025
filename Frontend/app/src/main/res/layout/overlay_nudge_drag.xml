<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/nudge_drag_root"
    android:layout_width="120dp"
    android:layout_height="140dp"
    android:elevation="12dp">

    <!-- 방패 이미지 -->
    <ImageView
        android:id="@+id/img_muscle"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/overlay_kettlebell"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true" />

    <!-- 텍스트 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="8dp">

        <TextView
            android:id="@+id/tv_nudge_drag_word"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ephemeral"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/dnfforgedblade_bold"
            android:layout_marginBottom="4dp"
            android:layout_marginTop="40dp"/>

        <TextView
            android:id="@+id/tv_nudge_drag_meaning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="일시적인"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:fontFamily="@font/dnfforgedblade_medium"/>

    </LinearLayout>

</FrameLayout>