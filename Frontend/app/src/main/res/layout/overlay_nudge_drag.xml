<?xml version="1.0" encoding="utf-8"?>
<!-- 넛지 ① 방패 테마 — Figma 디자인 적용 (전체화면) -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/nudge_drag_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 배경 이미지 (실제 사진으로 교체 예정: res/drawable/bg_nudge_shield.jpg) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_primary_navy" />

    <!-- 어두운 딤 rgba(61,61,61,0.4) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_dark_dim" />

    <!-- 중앙 콘텐츠 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- 방패 이미지 (실제 이미지로 교체 예정) -->
        <ImageView
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginBottom="40dp"
            android:background="@color/overlay_accent_yellow"
            android:contentDescription="방패 이미지"
            android:scaleType="centerCrop" />

        <!-- 단어 -->
        <TextView
            android:id="@+id/tv_nudge_drag_word"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="ephemeral"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- 뜻 -->
        <TextView
            android:id="@+id/tv_nudge_drag_meaning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="48dp"
            android:gravity="center"
            android:text="일시적인, 단명하는"
            android:textColor="#CCffffff"
            android:textSize="16sp" />

        <!-- 드래그 진행 바 -->
        <ProgressBar
            android:id="@+id/progress_drag"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="240dp"
            android:layout_height="10dp"
            android:layout_marginBottom="12dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/overlay_accent_yellow" />

        <!-- 안내 문구 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/drag_instruction"
            android:textColor="#99ffffff"
            android:textSize="13sp" />

    </LinearLayout>

</FrameLayout>
