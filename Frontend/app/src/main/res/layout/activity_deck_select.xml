<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@color/main_navy">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/white"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="덱 선택 / 관리"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/btn_new_deck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="새 덱 구성"
            android:textSize="12sp"
            android:backgroundTint="#F4C400"
            android:textColor="@color/main_navy"
            style="@style/Widget.MaterialComponents.Button" />
    </LinearLayout>

    <!-- 안내 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="덱을 선택해 입장할 스테이지에 사용하세요. (최대 3개 덱 보관 가능)"
        android:textSize="12sp"
        android:textColor="@color/overlay_text_secondary"
        android:padding="12dp" />

    <!-- 덱 목록 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_decks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:clipToPadding="false" />

</LinearLayout>
