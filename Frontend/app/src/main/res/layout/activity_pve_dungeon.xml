<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E">

    <!-- 상단: 스테이지 / 턴 / 라운드 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#2A2A4E">

        <TextView
            android:id="@+id/tv_stage_round"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="스테이지 1 · 라운드 1/5"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/tv_turn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="턴 1"
            android:textSize="13sp"
            android:textColor="#F4C400" />
    </LinearLayout>

    <!-- 플레이어 상태이상 표시 -->
    <TextView
        android:id="@+id/tv_player_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="#FFD700"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:visibility="gone" />

    <!-- 몬스터 영역 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_monsters"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false" />

    <!-- 플레이어 HP -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#2A2A4E">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🧙 플레이어"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/tv_player_hp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="500 / 500"
                    android:textSize="13sp"
                    android:textColor="#7FFF7F" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/pb_player_hp"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:max="100"
                android:progress="100"
                android:progressTint="#4CAF50"
                android:progressBackgroundTint="#333355" />

            <TextView
                android:id="@+id/tv_player_buffs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="11sp"
                android:textColor="#FFD700"
                android:layout_marginTop="4dp"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333355"
        android:layout_marginHorizontal="12dp" />

    <!-- 카드 영역 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="사용 가능한 카드"
            android:textSize="12sp"
            android:textColor="#AAAACC" />

        <TextView
            android:id="@+id/tv_available_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 / 0장"
            android:textSize="12sp"
            android:textColor="#AAAACC" />
    </LinearLayout>

    <!-- 카드 가로 스크롤 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_cards"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:paddingHorizontal="8dp"
        android:clipToPadding="false" />

    <!-- 포기 버튼 -->
    <Button
        android:id="@+id/btn_retreat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginVertical="8dp"
        android:text="던전 포기"
        android:textSize="13sp"
        android:backgroundTint="#8B0000"
        style="@style/Widget.MaterialComponents.Button" />

</LinearLayout>
