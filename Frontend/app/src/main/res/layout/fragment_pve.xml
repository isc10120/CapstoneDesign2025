<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@color/main_navy">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚔ PVE 던전"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/btn_deck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="덱 구성"
            android:textSize="13sp"
            android:backgroundTint="#F4C400"
            android:textColor="@color/main_navy"
            style="@style/Widget.MaterialComponents.Button" />
    </LinearLayout>

    <!-- 활성 덱 정보 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="선택된 덱:"
                android:textSize="13sp"
                android:textColor="@color/overlay_text_secondary" />

            <TextView
                android:id="@+id/tv_active_deck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="덱 없음 - 덱 구성 후 선택해주세요"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/main_navy" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 진행 중인 스테이지 카드 (전투 중일 때만 표시) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_continue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:cardCornerRadius="10dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#FFF8E1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚔ 진행 중인 스테이지"
                    android:textSize="12sp"
                    android:textColor="@color/overlay_text_secondary"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tv_continue_stage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/main_navy" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_continue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="이어서 진행"
                android:textSize="13sp"
                android:backgroundTint="#FF9800"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 랜덤 던전 입장 버튼 -->
    <Button
        android:id="@+id/btn_enter_random"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="12dp"
        android:text="🎲 랜덤 던전 도전"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="@color/main_navy"
        style="@style/Widget.MaterialComponents.Button" />

    <!-- 스테이지 현황 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="스테이지 현황"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/overlay_text_secondary"
        android:paddingHorizontal="16dp"
        android:paddingBottom="4dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_stages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:clipToPadding="false" />

</LinearLayout>
