<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="방해금지 앱 설정"
        android:textColor="@color/main_navy"
        android:textSize="22sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="16dp"
        android:background="@color/overlay_card_stroke" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:lineSpacingExtra="4dp"
        android:text="체크한 앱을 사용하는 동안에는 넛지 오버레이가 표시되지 않습니다.\n게임, 영상, 회의 앱 등 집중이 필요한 앱을 선택하세요."
        android:textColor="@color/overlay_text_secondary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tv_usage_permission_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:padding="10dp"
        android:text="앱 사용 기록 권한 확인 중..."
        android:textSize="13sp" />

    <Button
        android:id="@+id/btn_request_usage_permission"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="앱 사용 기록 접근 권한 허용 →"
        android:textSize="13sp"
        style="@style/Widget.Material3.Button.OutlinedButton" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_apps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_dnd_save"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:backgroundTint="@color/main_navy"
        android:text="저장" />

    <Button
        android:id="@+id/btn_dnd_back"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="뒤로가기"
        style="@style/Widget.Material3.Button.OutlinedButton" />

</LinearLayout>
