<?xml version="1.0" encoding="utf-8"?>
<!-- 아침 오버레이 2 (테마 선택 후) — Figma 디자인 적용 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/word_card_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 배경 이미지 (실제 사진으로 교체 예정: res/drawable/bg_morning.jpg) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_primary_navy" />

    <!-- 어두운 딤 오버레이 rgba(61,61,61,0.4) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_dark_dim" />

    <!-- 흰색 외부 카드 (border-radius 22dp) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="24dp"
        android:background="@drawable/overlay_outer_card_bg"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 상단: 제목 + 진행상황 + 닫기 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="오늘의 수련"
                android:textColor="@color/overlay_primary_navy"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_word_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="1/10"
                android:textColor="@color/overlay_primary_navy"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_close_word_list"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:backgroundTint="@android:color/transparent"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:text="✕"
                android:textColor="@color/overlay_primary_navy"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- 노란색 카드 (border-radius 45dp, rgba(244,196,0,0.7)) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/overlay_yellow_card_bg"
            android:padding="14dp">

            <!-- 내부 흰색 단어 박스 (border-radius 32dp) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/overlay_inner_word_box_bg"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- 단어 -->
                <TextView
                    android:id="@+id/tv_word"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="Monopoly"
                    android:textColor="@color/overlay_primary_navy"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <!-- 뜻 (한국어) -->
                <TextView
                    android:id="@+id/tv_meaning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center"
                    android:text="독점; 전매"
                    android:textColor="@color/overlay_text_primary"
                    android:textSize="16sp" />

                <!-- 예문 (예문이 있을 때만 표시) -->
                <TextView
                    android:id="@+id/tv_example"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/overlay_text_secondary"
                    android:textSize="13sp"
                    android:visibility="gone" />

            </LinearLayout>
        </FrameLayout>

        <!-- 하단 네비게이션 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <Button
                android:id="@+id/btn_prev_word"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:backgroundTint="@android:color/transparent"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:text="‹"
                android:textColor="@color/overlay_primary_navy"
                android:textSize="24sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="← 스와이프 →"
                android:textColor="@color/overlay_text_hint"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_next_word"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:backgroundTint="@android:color/transparent"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:text="›"
                android:textColor="@color/overlay_primary_navy"
                android:textSize="24sp" />
        </LinearLayout>

    </LinearLayout>

    <!-- header_drag_handle: 전체화면이라 드래그 불필요, Kotlin 호환용으로만 유지 -->
    <View
        android:id="@+id/header_drag_handle"
        android:layout_width="0dp"
        android:layout_height="0dp" />

</FrameLayout>
