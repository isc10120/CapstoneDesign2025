<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- 카드 전체 -->
    <LinearLayout
        android:id="@+id/word_card"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/overlay_outer_card_bg"
        android:padding="16dp"
        android:elevation="8dp"
        android:clickable="true"
        android:focusable="true">

        <!-- 헤더 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 제목 -->
            <TextView
                android:id="@+id/tv_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="오늘의 단어 (1/10)"
                android:textColor="@color/main_navy"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/dnfforgedblade_bold" />

            <!-- 닫기 버튼 -->
            <Button
                android:id="@+id/btn_close"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="end"
                android:text="✕"
                android:textSize="20sp"
                android:textColor="@color/main_navy"
                android:background="@android:color/transparent"
                android:stateListAnimator="@null"
                android:elevation="0dp" />
        </FrameLayout>

        <!-- 🔥 스와이프 대상 영역 -->
        <LinearLayout
            android:id="@+id/card_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:background="@drawable/overlay_yellow_card_bg"
            android:padding="16dp">

            <!-- 단어 -->
            <TextView
                android:id="@+id/tv_word"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Monopoly"
                android:textColor="@color/main_navy"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="@font/dnfforgedblade_bold" />

            <!-- 내부 박스 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:background="@drawable/overlay_inner_word_box_bg"
                android:padding="16dp">

                <!-- 뜻 -->
                <TextView
                    android:id="@+id/tv_meaning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. 독점\n2. 전유물"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:textColor="@color/black"
                    android:fontFamily="@font/dnfforgedblade_bold" />

                <!-- 예문 (영어) -->
                <TextView
                    android:id="@+id/tv_example_en"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Example sentence"
                    android:textSize="14sp"
                    android:textStyle="italic"
                    android:gravity="center"
                    android:textColor="@color/black"
                    android:fontFamily="@font/dnfforgedblade_medium" />

                <!-- 예문 (한글) -->
                <TextView
                    android:id="@+id/tv_example_kr"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="예문 번역"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:textColor="@color/black"
                    android:fontFamily="@font/dnfforgedblade_medium" />
            </LinearLayout>
        </LinearLayout>

        <!-- 점 indicator -->
        <LinearLayout
            android:id="@+id/dot_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            android:orientation="horizontal" />

    </LinearLayout>

</FrameLayout>