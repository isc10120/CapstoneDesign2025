<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 스킬 카드 정보 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#2A2A4E"
            app:cardCornerRadius="14dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- 스킬명 + 등급 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_card_skill_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="스킬명"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_card_grade"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_count_badge"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="동급"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 효과 + 데미지 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_card_effect"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⚔ 공격"
                        android:textColor="#F4C400"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_card_damage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="데미지: 50"
                        android:textColor="#FF7777"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 문제 유형 라벨 -->
        <TextView
            android:id="@+id/tv_question_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="✏ 문제 로딩 중..."
            android:textColor="#AAAACC"
            android:textSize="13sp" />

        <!-- 문제 카드 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#2A2A4E"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_korean_sentence"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:lineSpacingMultiplier="1.3"
                    android:text="문제 로딩 중..."
                    android:textColor="@color/white"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tv_word_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#33445566"
                    android:fontFamily="monospace"
                    android:padding="8dp"
                    android:text=""
                    android:textColor="#AAAACC"
                    android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 객관식 선택지 -->
        <LinearLayout
            android:id="@+id/ll_options"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="vertical"
            android:visibility="gone">

            <Button
                android:id="@+id/btn_option_0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:backgroundTint="#3A3A6E"
                android:text=""
                android:textColor="@color/white"
                android:textSize="14sp"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/btn_option_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:backgroundTint="#3A3A6E"
                android:text=""
                android:textColor="@color/white"
                android:textSize="14sp"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/btn_option_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:backgroundTint="#3A3A6E"
                android:text=""
                android:textColor="@color/white"
                android:textSize="14sp"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/btn_option_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#3A3A6E"
                android:text=""
                android:textColor="@color/white"
                android:textSize="14sp"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

        <!-- 주관식 답안 입력 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_answer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:hint="답을 입력하세요"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_answer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 스킬 발동 버튼 -->
        <Button
            android:id="@+id/btn_submit"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#F4C400"
            android:text="⚔ 스킬 발동!"
            android:textColor="@color/main_navy"
            android:textSize="15sp"
            android:textStyle="bold"
            style="@style/Widget.MaterialComponents.Button" />

        <!-- 다른 카드 선택 -->
        <Button
            android:id="@+id/btn_skip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:backgroundTint="#3A3A5E"
            android:text="다른 카드 선택"
            android:textColor="#AAAACC"
            android:textSize="13sp"
            style="@style/Widget.MaterialComponents.Button" />

        <!-- 피드백 -->
        <TextView
            android:id="@+id/tv_feedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:lineSpacingMultiplier="1.3"
            android:padding="14dp"
            android:text=""
            android:textSize="14sp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
